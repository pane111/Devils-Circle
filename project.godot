[dialogue_manager]

runtime/balloon_path="uid://13s5spsk34qu"

[display]

window/size/viewport_width=400
window/size/viewport_height=240
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/character_creator/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/extra_nodes/plugin.cfg")

[global_group]

interactable=""
slashable="Can be slashed by the player"

[gui]

